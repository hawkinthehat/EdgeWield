## NEXT.JS PUBLIC URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_URL=http://localhost:3000

## SUPABASE (Database & Auth)
# Get these from: Settings > API in your Supabase Dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-for-admin-actions

## THE ODDS API (Live Data)
# Get this from: https://the-odds-api.com/
ODDS_API_KEY=your-api-key-here

## STRIPE (Payments)
# Get these from: Developers > API keys in Stripe Dashboard
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# The ID of the monthly product price you created in Stripe
STRIPE_PREMIUM_PRICE_ID=price_...

## RESEND (Weekly CFO Emails)
# Get this from: https://resend.com/
RESEND_API_KEY=re_...
