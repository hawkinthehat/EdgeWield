#
# Local development environment template
# Copy to .env and fill values:
#   cp .env.example .env
#

# --- Ports used by `pnpm dev` ---
API_PORT=4000
WEB_PORT=5173

# Base path for the web app (usually "/")
BASE_PATH=/

# Vite proxy target for /api requests from the web app
VITE_API_PROXY_TARGET=http://localhost:4000

# --- Web (client) env ---
# Supabase public URL and anon key for browser auth/session flows
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- API server env ---
# Required for odds scanning routes
ODDS_API_KEY=

# Required for server-side Supabase operations
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional Stripe billing config
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_STANDARD_PRICE_ID=

# Optional, used to build checkout return/cancel URLs in server
# Example: myapp.repl.co
REPLIT_DOMAINS=

# Optional notifications
DISCORD_WEBHOOK_URL=

# Optional logging level (default: info)
LOG_LEVEL=info

# Optional database URL used by lib/db tooling/migrations
DATABASE_URL=
