# --- NEXT.JS PUBLIC URL ---
# Keep both for compatibility across routes/components in this repo.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_URL=http://localhost:3000

# --- SUPABASE (Database & Auth) ---
# Get these from: Settings > API in your Supabase Dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-for-admin-actions

# --- THE ODDS API (Live Data) ---
# Get this from: https://the-odds-api.com/
# Primary key used by scanner and sync jobs.
THE_ODDS_API_KEY=your-api-key-here
# Backward-compatible alias used by some legacy endpoints.
ODDS_API_KEY=your-api-key-here

# --- STRIPE (Payments) ---
# Get these from: Developers > API keys in Stripe Dashboard
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Stripe price IDs for each checkout tier
STRIPE_PRICE_ID_SCOUT=price_...
STRIPE_PRICE_ID_PRO=price_...

# Optional local bypass for pre-webhook QA
# NEXT_PUBLIC_ENABLE_PRO_BYPASS=false
# NEXT_PUBLIC_DEV_BYPASS_EMAIL=you@example.com

# --- RESEND (Weekly CFO Emails) ---
# Get this from: https://resend.com/
RESEND_API_KEY=re_...
